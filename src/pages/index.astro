---
import { Icon } from 'astro-icon/components';
import Default from '../components/layouts/Default.astro';
import { site } from '../site';
import Section from '../components/base/Section.astro';
import Card from '../components/base/Card.astro';
import VTodo from '../data/products/v-todo/v-todo.png'

const services = [
  { id: 'web-development', name: 'Pembuatan Website', startFrom: '300.000', url: 'https://forms.gle/dHExo76zNqscGvSSA' },
  { id: 'app-development', name: 'Pembuatan Aplikasi', startFrom: '1.000.000', url: 'https://forms.gle/UT3Kr3yA7bihMwiK8' },
  { id: 'server-management', name: 'Pengelolaan Server', startFrom: '1.000.000', url: 'https://forms.gle/5LBt6J4hnefSopbG8' },
]

const posts = [
  {
    title: 'Membangun Website Modern dengan React & Tailwind',
    date: '15 Jan 2025',
    summary: 'Panduan lengkap membangun website modern yang cepat dan responsif menggunakan React dan Tailwind CSS.'
  },
  {
    title: '5 Tips UI/UX untuk Meningkatkan Konversi',
    date: '10 Jan 2025',
    summary: 'Pelajari bagaimana desain yang baik dapat meningkatkan konversi bisnis online Anda secara signifikan.'
  },
  {
    title: 'Optimasi Performa Website: Dari Lambat ke Kilat',
    date: '5 Jan 2025',
    summary: 'Teknik-teknik praktis untuk mempercepat loading website dan meningkatkan pengalaman pengguna.'
  }
]

const products = [
  {
    name: 'V-Todo - Board Based Task Management',
    description: 'Simple but powerfull board based task management.',
    price: 'free',
    image: VTodo,
    url: '/v-todo'
  }
]
---

<Default>
<header class="space-y-2">
      <h1 class="text-3xl font-bold text-red-500 tracking-tight">narakode<span class="text-neutral-400">.id</span></h1>
      <p class="text-lg leading-relaxed text-neutral-400">{site.description}.</p>
    </header>
    <main class="space-y-8">
      <Section title="Layanan">
        {services.map(service => <Card tag="article" class="flex items-center justify-between">
          <div class="space-y-1">
            <h3 class="font-medium">{service.name}</h3>
            <p class="text-sm text-neutral-400">Mulai dari <strong class="text-white">{service.startFrom}</strong></p>
          </div>
          <a href={service.url} class="text-red-500 flex items-center gap-2 font-medium transition px-3 h-9 rounded-md hover:bg-red-500/20 focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:outline-none">
            <span class="hidden sm:block">Pesan</span> 
            <Icon name="tabler:arrow-right" class="size-4" />
          </a>
        </Card>)}
      </Section>
      <Section title="Produk">
        <div class="grid sm:grid-cols-2">
          {products.map(product => <Card tag="article" image={product.image} title={product.name}>
            <div class="space-y-1">
              <h3 class="font-medium">
                <a href={product.url} class="hover:underline">{product.name}</a>
              </h3>
              <p class="text-sm text-neutral-400">{product.description}</p>
            </div>
          </Card>)}
        </div>
      </Section>
      <!-- <section class="space-y-4">
        <h2 class="text-sm font-medium tracking-wider text-neutral-400 uppercase">Post</h2>

        <div class="space-y-4">
          {posts.map(post => <article class="space-y-1">
            <p class="text-sm text-neutral-400">{post.date}</p>
            <h3 class="font-medium">
              <a class="hover:text-red-500" href="">{post.title}</a>
            </h3>
            <p class="text-sm text-neutral-400">{post.summary}</p>
          </article>)}

          <div class="flex justify-center">
            <a href="" class="text-red-500 inline-flex items-center gap-2 font-medium transition px-3 h-9 rounded-md hover:bg-red-500/20 focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:outline-none">
              <span class="hidden sm:block">Lihat Semua Artikel</span> 
              <Icon name="tabler:arrow-right" class="size-4" />
            </a>
          </div>
        </div>
      </section> -->
    </main>
    
    </Default>