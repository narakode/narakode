---
const { title, description, color, level = 2, size = 'md', centered = true, class: propsClass } = Astro.props

const TitleElement = `h${level}`

const titleColorClass = {
    white: 'text-white',
    black: 'text-neutral-900'
}[color]
const subtitleColorClass = {
    white: 'text-white',
    black: 'text-neutral-600'
}[color]
const titleSizeClass = {
    md: 'text-3xl md:text-4xl',
    sm: 'text-2xl md:text-3xl'
}[size]
const subtitleSizeClass = {
    md: 'text-lg md:text-xl',
    sm: 'text-base md:text-lg'
}[size]
---

<header class=`w-full md:max-w-3xl mx-auto space-y-4 ${centered && 'text-center'} ${propsClass ?? ''}`>
    <div class="space-y-2">
        <TitleElement {...{ class: `font-bold ${titleSizeClass} tracking-tight ${titleColorClass}` }}>{title}</TitleElement>
        <p class={`${subtitleSizeClass} md:leading-normal ${subtitleColorClass}`}>{description}</p>
    </div>
    <slot name="cta" />
</header>