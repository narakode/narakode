---
const { title, description, color, level = 2 } = Astro.props

const TitleElement = `h${level}`

const titleColorClass = {
    white: 'text-white',
    black: 'text-neutral-900'
}[color]
const subtitleColorClass = {
    white: 'text-white',
    black: 'text-neutral-600'
}[color]
---

<header class="max-w-3xl mx-auto space-y-2 text-center">
    <TitleElement {...{ class: `font-bold text-3xl md:text-4xl tracking-tight ${titleColorClass}` }}>{title}</TitleElement>
    <p class={`text-lg md:text-xl md:leading-normal ${subtitleColorClass}`}>{description}</p>
</header>